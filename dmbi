using System;
using System.Web.UI;

namespace WebApplication1
{
    public partial class _default : Page
    {
        protected void Page_Load(object sender, EventArgs e)
        {
        }

        protected void btnFib_Click(object sender, EventArgs e)
        {
            int n = int.Parse(txtFib.Text);
            int a = 0, b = 1;
            string result = "0 1 ";
            
            for (int i = 2; i < n; i++)
            {
                int c = a + b;
                result += c + " ";
                a = b;
                b = c;
            }
            lblFib.Text = result;
        }

        protected void btnPrime_Click(object sender, EventArgs e)
        {
            int n = int.Parse(txtPrime.Text);
            bool prime = true;
            
            for (int i = 2; i <= n / 2; i++)
            {
                if (n % i == 0)
                {
                    prime = false;
                    break;
                }
            }
            lblPrime.Text = prime ? "Prime Number" : "Not a Prime Number";
        }

        protected void btnVowel_Click(object sender, EventArgs e)
        {
            char ch = char.Parse(txtVowel.Text.ToLower());
            
            if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u')
                lblVowel.Text = "It is a Vowel";
            else
                lblVowel.Text = "It is not a Vowel";
        }

        protected void btnReverse_Click(object sender, EventArgs e)
        {
            int n = int.Parse(txtReverse.Text);
            int rev = 0, sum = 0;
            
            while (n > 0)
            {
                int d = n % 10;
                rev = rev * 10 + d;
                sum += d;
                n /= 10;
            }
            lblReverse.Text = "Reverse: " + rev + " | Sum of digits: " + sum;
        }
    }
}

