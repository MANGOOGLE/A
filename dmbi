using System;
using System.Web.UI;

namespace WebApplication1
{
    public partial class _default : Page
    {
        protected void Page_Load(object sender, EventArgs e)
        {
        }

        protected void btnFact_Click(object sender, EventArgs e)
        {
            int n = int.Parse(txtFact.Text);
            int fact = 1;
            
            for (int i = 1; i <= n; i++)
                fact *= i;
                
            lblFact.Text = "Factorial = " + fact;
        }

        protected void btnMoney_Click(object sender, EventArgs e)
        {
            double usd = double.Parse(txtMoney.Text);
            double inr = usd * 80; // simple fixed rate for exam
            
            lblMoney.Text = "Amount in INR = " + inr;
        }

        protected void btnQuad_Click(object sender, EventArgs e)
        {
            double a = double.Parse(txtA.Text);
            double b = double.Parse(txtB.Text);
            double c = double.Parse(txtC.Text);
            
            double d = (b * b) - (4 * a * c);
            double r1 = (-b + Math.Sqrt(d)) / (2 * a);
            double r2 = (-b - Math.Sqrt(d)) / (2 * a);
            
            lblQuad.Text = "Roots are: " + r1 + " and " + r2;
        }

        protected void btnTemp_Click(object sender, EventArgs e)
        {
            double t = double.Parse(txtTemp.Text);
            
            if (ddlTemp.SelectedValue == "CtoF")
                lblTemp.Text = "Result = " + ((t * 9 / 5) + 32);
            else
                lblTemp.Text = "Result = " + ((t - 32) * 5 / 9);
        }
    }
}

